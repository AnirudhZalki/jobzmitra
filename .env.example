# JobzMitra Environment Variables

# Database Configuration (Docker Compose handles this automatically)
# But you can override it if needed.
# DATABASE_URL="postgresql://postgres:Ani%23%40123@db:5432/jobzmitradb"

# Security
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"

# Cloudinary (Required for media uploads)
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_API_KEY"
CLOUDINARY_API_SECRET="YOUR_API_SECRET"
